{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Proof Inventory",
  "type": "object",
  "required": [
    "verified_abilities",
    "proof_limitations",
    "approved_positioning",
    "future_proof_to_collect"
  ],
  "properties": {
    "verified_abilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "proof_limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "approved_positioning": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "future_proof_to_collect": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
